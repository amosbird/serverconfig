#!/usr/bin/env python3

import json
import os
import socket
import struct
import subprocess
import sys
import http.client
import base64


XSETTINGSD_CONF = os.path.expanduser("~/.xsettingsd")
VIVALDI_DEBUG_PORT = 9222


def get_theme():
    try:
        val = subprocess.check_output(
            ["gsettings", "get", "org.gnome.desktop.interface", "color-scheme"],
            stderr=subprocess.DEVNULL,
            text=True,
        )
        return "dark" if "dark" in val else "light"
    except Exception:
        return "dark"


def set_gsettings(mode):
    scheme = "prefer-dark" if mode == "dark" else "prefer-light"
    subprocess.run(
        ["gsettings", "set", "org.gnome.desktop.interface", "color-scheme", scheme],
        check=True,
    )


def set_xsettingsd(mode):
    gtk_theme = "Adwaita-dark" if mode == "dark" else "Adwaita"
    try:
        with open(XSETTINGSD_CONF) as f:
            lines = f.readlines()
        with open(XSETTINGSD_CONF, "w") as f:
            for line in lines:
                if line.startswith("Net/ThemeName"):
                    f.write(f'Net/ThemeName "{gtk_theme}"\n')
                else:
                    f.write(line)
        subprocess.run(["pkill", "-USR1", "xsettingsd"], check=False)
    except FileNotFoundError:
        pass


def cdp_ws_call(ws_url, msg_id, method, params):
    host_port = ws_url.split("//")[1].split("/")[0]
    path = "/" + "/".join(ws_url.split("/")[3:])
    host, sport = host_port.rsplit(":", 1)

    sock = socket.create_connection((host, int(sport)), timeout=5)

    key = base64.b64encode(os.urandom(16)).decode()
    handshake = (
        f"GET {path} HTTP/1.1\r\n"
        f"Host: {host}:{sport}\r\n"
        f"Upgrade: websocket\r\n"
        f"Connection: Upgrade\r\n"
        f"Sec-WebSocket-Key: {key}\r\n"
        f"Sec-WebSocket-Version: 13\r\n"
        f"\r\n"
    )
    sock.sendall(handshake.encode())

    buf = b""
    while b"\r\n\r\n" not in buf:
        buf += sock.recv(4096)

    msg = json.dumps({"id": msg_id, "method": method, "params": params})
    ws_send(sock, msg.encode())
    raw = ws_recv(sock)
    sock.close()
    try:
        return json.loads(raw).get("result")
    except Exception:
        return None


def set_vivaldi_pref(mode):
    try:
        conn = http.client.HTTPConnection("127.0.0.1", VIVALDI_DEBUG_PORT, timeout=2)
        conn.request("GET", "/json")
        pages = json.loads(conn.getresponse().read())
        conn.close()
    except Exception:
        return

    candidates = [p for p in pages if p.get("type") in ("app", "background_page")]
    candidates += [p for p in pages if p not in candidates]

    expr = (
        f"typeof vivaldi !== 'undefined' && typeof vivaldi.prefs !== 'undefined' "
        f"&& vivaldi.prefs.set({{path: 'vivaldi.system.desktop_theme_color', value: '{mode}'}})"
    )
    for page in candidates:
        ws_url = page.get("webSocketDebuggerUrl")
        if not ws_url:
            continue
        try:
            resp = cdp_ws_call(ws_url, 1, "Runtime.evaluate", {
                "expression": expr,
                "returnByValue": True,
            })
            if resp and resp.get("result", {}).get("value") is not False:
                break
        except Exception:
            continue


def ws_send(sock, data):
    mask = os.urandom(4)
    length = len(data)
    header = bytearray([0x81])
    if length < 126:
        header.append(0x80 | length)
    elif length < 65536:
        header.append(0x80 | 126)
        header.extend(struct.pack(">H", length))
    else:
        header.append(0x80 | 127)
        header.extend(struct.pack(">Q", length))
    header.extend(mask)
    masked = bytearray(b ^ mask[i % 4] for i, b in enumerate(data))
    sock.sendall(header + masked)


def ws_recv(sock):
    header = sock.recv(2)
    if len(header) < 2:
        return b""
    length = header[1] & 0x7F
    if length == 126:
        length = struct.unpack(">H", sock.recv(2))[0]
    elif length == 127:
        length = struct.unpack(">Q", sock.recv(8))[0]
    data = b""
    while len(data) < length:
        data += sock.recv(length - len(data))
    return data


def set_windows_theme(mode):
    try:
        subprocess.run(["pgrep", "-x", "xfreerdp"], check=True,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return
    value = 0 if mode == "dark" else 1
    cmd = (
        f'powershell -NoProfile -Command "'
        f"Set-ItemProperty -Path HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize "
        f"-Name AppsUseLightTheme -Value {value}; "
        f"Set-ItemProperty -Path HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize "
        f"-Name SystemUsesLightTheme -Value {value}; "
        f"Add-Type -TypeDefinition 'using System; using System.Runtime.InteropServices; "
        f"public class NativeMethods {{ "
        f"[DllImport(\\\"user32.dll\\\", SetLastError = true, CharSet = CharSet.Auto)] "
        f"public static extern IntPtr SendMessageTimeout(IntPtr hWnd, uint Msg, UIntPtr wParam, string lParam, uint fuFlags, uint uTimeout, out UIntPtr lpdwResult); "
        f"}}'; "
        f"[UIntPtr]$result = [UIntPtr]::Zero; "
        f"[NativeMethods]::SendMessageTimeout([IntPtr]0xffff, 0x1a, [UIntPtr]::Zero, 'ImmersiveColorSet', 2, 5000, [ref]$result)"
        f'"'
    )
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.sendto((cmd + "\n").encode(), ("127.0.0.1", 9333))
        sock.close()
    except OSError:
        pass


def set_theme(mode):
    set_gsettings(mode)
    set_xsettingsd(mode)
    set_vivaldi_pref(mode)
    set_windows_theme(mode)


def main():
    args = sys.argv[1:]
    if not args or args[0] == "toggle":
        current = get_theme()
        mode = "light" if current == "dark" else "dark"
    elif args[0] in ("dark", "light"):
        mode = args[0]
    else:
        print("usage: theme [dark|light|toggle]", file=sys.stderr)
        sys.exit(1)

    set_theme(mode)
    print(mode)


if __name__ == "__main__":
    main()
