#!/usr/bin/env bash

LOG="/tmp/startup.log"
echo "=== startup begin: $(date '+%Y-%m-%d %H:%M:%S') ===" > "$LOG"

run() {
    local label="$1"
    shift
    echo "[$(date '+%H:%M:%S')] START $label" >> "$LOG"
    if "$@"; then
        echo "[$(date '+%H:%M:%S')]    OK $label" >> "$LOG"
    else
        echo "[$(date '+%H:%M:%S')]  FAIL $label (exit=$?)" >> "$LOG"
    fi
}

run_bg() {
    local label="$1"
    shift
    echo "[$(date '+%H:%M:%S')] START $label (bg)" >> "$LOG"
    "$@" &
    echo "[$(date '+%H:%M:%S')]    OK $label (pid=$!)" >> "$LOG"
}

run_fish_bg() {
    local label="$1"
    shift
    local cmd="$*"
    echo "[$(date '+%H:%M:%S')] START $label (fish bg)" >> "$LOG"
    fish -c "$cmd" &
    echo "[$(date '+%H:%M:%S')]    OK $label (pid=$!)" >> "$LOG"
}

run_bg "caps-indicator" caps-indicator
run "xset-dpms" xset s off -dpms
run "xset-bell" xset b off
run "feh-wallpaper" timeout 5 feh --bg-fill ~/git/serverconfig/black_4k.jpg
run "picom" picom -b
run_bg "unclutter" unclutter --timeout 1 --jitter 10 -b --ignore-scrolling

echo "[$(date '+%H:%M:%S')] START xkeysnail (bg)" >> "$LOG"
sudo xkeysnail --watch /home/amos/git/serverconfig/xkeysnail.py &> /tmp/xkeysnail.log &
echo "[$(date '+%H:%M:%S')]    OK xkeysnail (pid=$!)" >> "$LOG"

run "xsetroot" xsetroot -cursor_name left_ptr

run_bg "kitty-portal" kitten desktop-ui run-server
run_bg "xdg-desktop-portal" /usr/lib/xdg-desktop-portal
run_bg "xsettingsd" xsettingsd

# /home/amos/scripts/moveend

run_fish_bg "dunst" "dunst &> /tmp/dunst.log &"
run_fish_bg "copyq" "copyq &> /tmp/copyq.log &"
# fish -c "runscrcpy  &> /dev/null &"
# fish -c "rungnirehtet &"
run_fish_bg "udiskie" "udiskie &> /tmp/udiskie.log &"
run "microsocks-fw" sudo iptables -C INPUT -p tcp --dport 8080 -i lo -j ACCEPT 2>/dev/null \
    || { sudo iptables -A INPUT -p tcp --dport 8080 -i lo -j ACCEPT; \
         sudo iptables -A INPUT -p tcp --dport 8080 -i tailscale0 -j ACCEPT; \
         sudo iptables -A INPUT -p tcp --dport 8080 -j REJECT; }
run_fish_bg "microsocks" "/home/amos/git/microsocks/microsocks -i 0.0.0.0 -p 8080 &> /tmp/microsocks.log &"
run_fish_bg "libinput-gestures" "libinput-gestures-setup start &> /tmp/gestures.log &"
run_fish_bg "clipserver" "clipserver -S &> /tmp/clipserver.log &"
run_fish_bg "v2raysocks" "pass show v2raysocks | v2ray -c /dev/stdin &> /tmp/v2raysocks.log &"
run_fish_bg "miniserve" "miniserve -i 127.0.0.1 -p 8099 /home/amos/git/serverconfig/amos.pac &"
# use to sync selection and clipboard. copyq sometimes fails to do that.
# fish -c "parcellite &> /tmp/parcellite.log &"
# fish -c "flameshot &> /tmp/flameshot.log &"
# fcitx
run_fish_bg "fcitx5" "fcitx5 -d"
# autocutsel -fork -selection PRIMARY
# autocutsel -fork -selection CLIPBOARD
run_fish_bg "hister" "/tmp/gentoo/opt/bin/hister listen &> /tmp/hister.log &"
run_fish_bg "kitty" "kitty &"

echo "=== startup end: $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$LOG"
