#!/usr/bin/env bash

# Media player wrapper: plays media files with mpv
# - Directory arg: recursively find and play all media files
# - File arg: play all media in same directory, starting from selected file

readonly COVER="$HOME/Pictures/cover.png"
readonly EXTENSIONS='mp[34]|m4[av]|aac|flac|webm|avi|ts|m[ko]v|ogg|opus|wma|wav'

mpv_opts=(
    --player-operation-mode=pseudo-gui
    --loop-playlist=inf
    --force-window
    --geometry=1280x800
    --image-display-duration=inf
    --vid=1
)
[[ -f "$COVER" ]] && mpv_opts+=(--external-file="$COVER")

target=$(realpath "$1")

if [[ -d "$target" ]]; then
    mapfile -t files < <(
        find "$target" -type f -regextype posix-extended \
            -iregex ".*\\.($EXTENSIONS)" | sort
    )

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "No media files found in: $target" >&2
        exit 1
    fi

    exec mpv "${mpv_opts[@]}" -- "${files[@]}"
else
    dir=$(dirname "$target")
    base=$(basename "$target")

    mapfile -t files < <(
        find "$dir" -maxdepth 1 -type f -regextype posix-extended \
            -iregex ".*\\.($EXTENSIONS)" | sort
    )

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "No media files found in: $dir" >&2
        exit 1
    fi

    # Find index of selected file for --playlist-start
    start=0
    for i in "${!files[@]}"; do
        if [[ "${files[$i]}" == "$target" ]]; then
            start=$i
            break
        fi
    done

    exec mpv "${mpv_opts[@]}" --playlist-start="$start" -- "${files[@]}"
fi
