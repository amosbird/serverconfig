#!/usr/bin/env bash

# opencode-search - Search opencode sessions by title and message content.
# Uses FTS5 index (separate DB) for fast full-text search with pinyin support.
# Intended to be run inside tmux display-popup (opencode tmux server).

DB="${HOME}/.local/share/opencode/opencode.db"
INDEX_DB="${HOME}/.local/share/opencode/search.db"
[ ! -f "$DB" ] && echo "DB not found: $DB" >&2 && exit 1

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

# --- Build / update FTS5 index (Go binary, ~11ms incremental) ---

"$SCRIPT_DIR/opencode-search-index" 2>/dev/null

# --- Search helper (called by fzf change:reload) ---

search() {
  local q="$1"
  if [ -z "$q" ]; then
    # No query: list all sessions by recency
    sqlite3 -separator $'\t' "$DB" "
      SELECT id, title,
        replace(directory, '$HOME/', '~/'),
        strftime('%m-%d', time_updated / 1000, 'unixepoch', 'localtime')
      FROM session
      WHERE title IS NOT NULL AND title != ''
      ORDER BY time_updated DESC;
    "
  else
    # Tokenize and sanitize input
    local tokens=()
    for token in $q; do
      token=$(printf '%s' "$token" | tr -d '"*^{}():')
      [ -n "$token" ] && tokens+=("$token")
    done
    [ ${#tokens[@]} -eq 0 ] && return

    # Build SQL: for each token, find sessions matching it in ANY column
    # (text, pinyin, initials, title), then INTERSECT all token results.
    # This lets "niantie bug" match pinyin "niantie" AND text "bug".
    local ctes="" intersect="" n=0
    for token in "${tokens[@]}"; do
      local safe_tok=$(printf '%s' "$token" | sed "s/'/''/g")
      local fts_tok="\"${safe_tok}\"*"
      local like_tok=$(printf '%s' "$safe_tok" | tr -d ' ')
      n=$((n + 1))
      ctes="${ctes}${ctes:+,}
      tok${n} AS (
        SELECT DISTINCT session_id FROM idx.part_fts
          WHERE text_content MATCH '${fts_tok}'
        UNION
        SELECT DISTINCT session_id FROM idx.part_fts
          WHERE pinyin_content MATCH '${fts_tok}'
        UNION
        SELECT DISTINCT session_id FROM idx.part_initials
          WHERE initials LIKE '%${like_tok}%'
        UNION
        SELECT id FROM session
          WHERE title LIKE '%${safe_tok}%'
      )"
      intersect="${intersect}${intersect:+
        INTERSECT
      }SELECT session_id FROM tok${n}"
    done

    sqlite3 -separator $'\t' "$DB" "
      ATTACH DATABASE '$INDEX_DB' AS idx;
      WITH ${ctes},
      all_matches AS (
        ${intersect}
      )
      SELECT s.id, s.title,
        replace(s.directory, '$HOME/', '~/'),
        strftime('%m-%d', s.time_updated / 1000, 'unixepoch', 'localtime')
      FROM session s
      JOIN all_matches m ON s.id = m.session_id
      WHERE s.title IS NOT NULL AND s.title != ''
      ORDER BY s.time_updated DESC;
      DETACH DATABASE idx;
    "
  fi
}

# --- Preview helper (called by fzf --preview) ---

preview() {
  local sid="$1"
  sqlite3 "$DB" "
    SELECT CASE json_extract(m.data, '\$.role')
             WHEN 'user' THEN '▶ '
             WHEN 'assistant' THEN '◀ '
             ELSE '  '
           END ||
      substr(
        replace(
          group_concat(
            CASE WHEN json_extract(p.data, '\$.type') = 'text'
                 THEN json_extract(p.data, '\$.text')
            END, ''
          ),
          char(10), ' '
        ), 1, 300
      )
    FROM message m
    LEFT JOIN part p ON p.message_id = m.id
    WHERE m.session_id = '$sid'
    GROUP BY m.id
    ORDER BY json_extract(m.data, '\$.createdAt') ASC
    LIMIT 50;
  "
}

# --- Main: dispatch by argument ---

case "${1:-}" in
  --search) search "$2" ; exit ;;
  --preview) preview "$2" ; exit ;;
esac

# --- fzf UI ---

SELF=$(readlink -f "$0")

selected=$(fzf \
  --delimiter=$'\t' \
  --with-nth='2,3,4' \
  --reverse --no-sort --cycle \
  --disabled \
  --header='Search sessions (title + content + pinyin)' \
  --bind="start:reload:\"$SELF\" --search ''" \
  --bind="change:reload:\"$SELF\" --search {q}" \
  --preview="\"$SELF\" --preview {1}" \
  --preview-window='right:50%:wrap' \
  --bind='esc:abort' \
)

[ -z "$selected" ] && exit 0

session_id=$(printf '%s' "$selected" | cut -f1)
session_title=$(printf '%s' "$selected" | cut -f2)
session_dir=$(sqlite3 "$DB" "SELECT directory FROM session WHERE id = '$session_id';")

# Match tmux window by pane_title prefix (opencode truncates to ~37 chars + "...")
title_prefix=$(printf '%s' "$session_title" | cut -c1-30)
match=$(tmux list-panes -a -F '#{window_index}'$'\t''#{pane_title}' 2>/dev/null |
  awk -F$'\t' -v p="OC | ${title_prefix}" 'index($2, p) == 1 {print $1; exit}')

if [ -n "$match" ]; then
  tmux select-window -t "$match"
else
  [ ! -d "$session_dir" ] && session_dir="$HOME"
  tmux new-window -c "$session_dir" "opencode --session '$session_id'"
fi
