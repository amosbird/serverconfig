#!/bin/bash
# fcitx5-context: per-window/pane input method state manager
# Works LOCALLY — calls fcitx5-remote directly via D-Bus
#
# Usage:
#   fcitx5-context save <context-id>
#   fcitx5-context restore <context-id>
#   fcitx5-context query
#   fcitx5-context clean [max-age-minutes]

STATE_DIR="/tmp/fcitx5-ctx-${UID:-$(id -u)}"
LOG_FILE="/tmp/fcitx5-im-debug.log"
LOG_ENABLE="/tmp/fcitx5-im-debug.enabled"  # touch to enable, rm to disable

_log() {
    [[ -e "$LOG_ENABLE" ]] || return 0
    local ts
    ts=$(date '+%F %T.%3N' 2>/dev/null || date '+%F %T')
    printf '%s [fcitx5-context pid=%s] %s\n' "$ts" "$$" "$*" >> "$LOG_FILE"
}

_query() {
    local active im_name
    active=$(fcitx5-remote 2>/dev/null) || return 1
    im_name=$(fcitx5-remote -n 2>/dev/null)
    echo "${active}:${im_name}"
}

_apply_state() {
    local data="$1"
    local active im_name
    active="${data%%:*}"
    im_name="${data#*:}"

    case "$active" in
        1) fcitx5-remote -c 2>/dev/null ;;
        2)
            if [[ -n "$im_name" ]]; then
                fcitx5-remote -s "$im_name" 2>/dev/null
            else
                fcitx5-remote -o 2>/dev/null
            fi
            ;;
        *)
            return 1
            ;;
    esac

    return 0
}

save() {
    local ctx_id="$1"
    [[ -z "$ctx_id" ]] && return 1
    mkdir -p "$STATE_DIR"
    local q
    q=$(_query)
    local rc=$?
    if [[ $rc -ne 0 ]]; then
        _log "save ctx=${ctx_id} query_failed rc=${rc}"
        return "$rc"
    fi
    local state_file tmp_file
    state_file="${STATE_DIR}/${ctx_id}"
    tmp_file="${state_file}.tmp.$$"

    printf '%s\n' "$q" > "$tmp_file" && mv -f "$tmp_file" "$state_file"
    _log "save ctx=${ctx_id} state=${q} file=${state_file}"
}

restore() {
    local ctx_id="$1"
    [[ -z "$ctx_id" ]] && return 1

    local state_file="${STATE_DIR}/${ctx_id}"
    if [[ ! -f "$state_file" ]]; then
        # No saved state: default to inactive (English).
        fcitx5-remote -c 2>/dev/null
        _log "restore ctx=${ctx_id} missing_state_file=${state_file} action=deactivate"
        return 0
    fi

    local data
    data=$(cat "$state_file")
    if ! _apply_state "$data"; then
        local cur_bad
        cur_bad=$(_query)
        _log "restore ctx=${ctx_id} bad_state=${data} file=${state_file} action=keep-current current=${cur_bad}"
        return 0
    fi

    local after
    after=$(_query)
    _log "restore ctx=${ctx_id} from=${data} to=${after} file=${state_file}"
}

clean() {
    local max_age="${1:-60}"
    [[ -d "$STATE_DIR" ]] || return 0
    _log "clean max_age=${max_age} dir=${STATE_DIR}"
    find "$STATE_DIR" -type f -mmin "+${max_age}" -delete 2>/dev/null
}

case "$1" in
    save)    save "$2" ;;
    restore) restore "$2" ;;
    query)   _query ;;
    clean)   clean "$2" ;;
    *)
        echo "Usage: fcitx5-context {save|restore|query|clean} [context-id|max-age]" >&2
        exit 1
        ;;
esac
