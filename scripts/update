#!/usr/bin/env bash

set -euo pipefail

needs_git_pkg_rebuild() {
    local pkg_name="$1"
    local remote_url="$2"

    pacman -Q "$pkg_name" >/dev/null 2>&1 || return 1

    local pkg_line remote_line installed remote
    pkg_line=$(pacman -Q "$pkg_name")
    if [[ "$pkg_line" =~ \.g([0-9a-f]+)-[0-9]+$ ]]; then
        installed="${BASH_REMATCH[1]}"
    else
        return 1
    fi

    remote_line=$(git ls-remote "$remote_url" HEAD)
    read -r remote _ <<< "$remote_line"
    remote="${remote:0:${#installed}}"

    [ -n "$installed" ] && [ -n "$remote" ] && [ "$installed" != "$remote" ]
}

vcs_packages=(
    "kitty-git"
    "freerdp-git"
    "xkeysnail-git"
)

vcs_remotes=(
    "https://github.com/amosbird/kitty.git"
    "https://github.com/amosbird/FreeRDP.git"
    "https://github.com/amosbird/xkeysnail.git"
)

rebuild_packages=()

paru -Sy --noconfirm archlinux-keyring
paru -Syu --noconfirm

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT

pids=()
for i in "${!vcs_packages[@]}"; do
    pkg_name="${vcs_packages[$i]}"
    remote_url="${vcs_remotes[$i]}"
    (
        if needs_git_pkg_rebuild "$pkg_name" "$remote_url"; then
            printf '%s\n' "$pkg_name" > "$tmp_dir/$i"
        fi
    ) &
    pids+=("$!")
done

for pid in "${pids[@]}"; do
    wait "$pid"
done

for i in "${!vcs_packages[@]}"; do
    marker="$tmp_dir/$i"
    if [ -f "$marker" ]; then
        rebuild_packages+=("$(<"$marker")")
    fi
done

if ((${#rebuild_packages[@]} > 0)); then
    paru -S --noconfirm --rebuild "${rebuild_packages[@]}"
fi
