#!/usr/bin/env bash

export DO_NOT_TRACK=1
export COLORTERM=truecolor

# MCP secrets — single `pass show` call. All four keys live in one
# entry (`mcp/env`) as KEY=value lines, so gpg only decrypts once.
set -a
eval "$(pass show mcp/env)"
set +a

CRASH_LOG="$HOME/.abush/logs/crash.log"
mkdir -p "$(dirname "$CRASH_LOG")"

ABUSH_BIN="$HOME/git/abush/target/release/abush"

# Always log to a known file so post-hoc debugging doesn't depend on
# the user having set ABUSH_LOG / RUST_LOG before launch.
export ABUSH_LOG="${ABUSH_LOG:-/tmp/abush.log}"
export RUST_LOG="${RUST_LOG:-abush_tui=info,abush_bus=info,abush_copilot=info,abush_store=warn}"

# TEMP perf diagnostic: log slow frames (>2ms) + slow keystroke/
# inbound handling to ABUSH_LOG, plus a baseline line every 120
# frames. Remove once the TUI lag root-cause is found.
export ABUSH_PERF=1

exec "$ABUSH_BIN" "$@" 2> >(tee -a "$CRASH_LOG" >&2)
