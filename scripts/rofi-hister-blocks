#!/usr/bin/env python3
"""
rofi-hister — Vivaldi tabs + Hister full-text history search via rofi-blocks.

Runs as the backend for rofi -modi blocks -show blocks -blocks-wrap rofi-hister.
Communicates with rofi-blocks via JSON on stdin/stdout.
"""

import http.client
import json
import re
import subprocess
import sys
import threading
import urllib.parse


VIVALDI_CDP_PORT = 9222
BLOCKLIST_SCRIPT = "/home/amos/scripts/rofi-browser-blocklist.sh"
HISTER_BIN = "hister"
GOOGLE_SEARCH_URL = "https://www.google.com/search?q="
URL_RE = re.compile(r"^(ftp|http|https)://[^ \"]+$")
DOMAIN_RE = re.compile(r"^(?:[a-zA-Z0-9-]+\.)+[a-zA-Z]{2,}(?:/\S*)?$")


entries = []
blocklist = []


def load_blocklist():
    try:
        out = subprocess.check_output(
            [BLOCKLIST_SCRIPT], stderr=subprocess.DEVNULL, text=True
        )
        patterns = []
        for line in out.strip().splitlines():
            parts = line.split(" ::: ", 1)
            if len(parts) == 2:
                patterns.append(re.compile(parts[1]))
        return patterns
    except Exception:
        return []


def is_blocked(url, bl):
    return any(p.search(url) for p in bl)


def get_vivaldi_tabs():
    try:
        conn = http.client.HTTPConnection("127.0.0.1", VIVALDI_CDP_PORT, timeout=1)
        conn.request("GET", "/json")
        pages = json.loads(conn.getresponse().read())
        conn.close()
        tabs = []
        for p in pages:
            url = p.get("url", "")
            title = p.get("title", "")
            if url and title and url.startswith(("http://", "https://", "file://")):
                tabs.append((title, url))
        return tabs
    except Exception:
        return []


def hister_search(query):
    if not query or not query.strip():
        return []
    tokens = query.split()
    prefixed = " ".join(t + "*" if not t.endswith("*") else t for t in tokens)
    try:
        out = subprocess.check_output(
            [HISTER_BIN, "search", "-f", "json", prefixed],
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=5,
        )
        data = json.loads(out)
        docs = data.get("documents") or []
        results = []
        seen = set()
        for d in docs:
            url = d.get("url", "")
            title = d.get("title", "") or url
            if url and url not in seen:
                seen.add(url)
                results.append((title, url))
        return results
    except Exception:
        return []


def match_query(query, title, url):
    q = query.lower()
    text = f"{title} {url}".lower()
    return all(tok in text for tok in q.split())


def build_tab_entries(query):
    bl = blocklist
    tabs = get_vivaldi_tabs()
    has_query = bool(query and query.strip())
    result = []
    seen = set()
    for title, url in tabs:
        if is_blocked(url, bl) or url in seen:
            continue
        if has_query and not match_query(query, title, url):
            continue
        seen.add(url)
        result.append(("tab", title, url))
    return result, seen


def build_hist_entries(query, seen):
    bl = blocklist
    history = hister_search(query)
    result = []
    for title, url in history:
        if is_blocked(url, bl) or url in seen:
            continue
        seen.add(url)
        result.append(("hist", title, url))
    return result


def format_lines(entry_list):
    lines = []
    for kind, title, url in entry_list:
        icon = "web-browser" if kind == "tab" else "clock"
        tag = "tab" if kind == "tab" else "hist"
        short_url = url.split("://", 1)[-1]
        display = f"[{tag}] {title}  <i>{short_url}</i>"
        lines.append({
            "text": display,
            "markup": True,
            "icon": icon,
            "data": json.dumps({"kind": kind, "url": url}),
        })
    return lines


def send(obj):
    sys.stdout.write(json.dumps(obj) + "\n")
    sys.stdout.flush()


def activate_vivaldi_tab(url):
    try:
        conn = http.client.HTTPConnection("127.0.0.1", VIVALDI_CDP_PORT, timeout=1)
        conn.request("GET", "/json")
        pages = json.loads(conn.getresponse().read())
        conn.close()
        for p in pages:
            if p.get("url") == url:
                page_id = p.get("id")
                if page_id:
                    conn2 = http.client.HTTPConnection(
                        "127.0.0.1", VIVALDI_CDP_PORT, timeout=1
                    )
                    conn2.request("GET", f"/json/activate/{page_id}")
                    conn2.getresponse()
                    conn2.close()
                return True
    except Exception:
        pass
    return False


def open_url(url):
    subprocess.Popen(
        ["qtile", "cmd-obj", "-o", "group", "f", "-f", "toscreen"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    subprocess.Popen(
        ["/home/amos/scripts/vivaldi", url],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def open_or_search(text):
    if not text or not text.strip():
        return
    text = text.strip()
    if URL_RE.match(text):
        url = text
    elif DOMAIN_RE.match(text):
        url = "https://" + text
    else:
        url = GOOGLE_SEARCH_URL + urllib.parse.quote_plus(text)
    open_url(url)


def open_entry(data):
    kind = data.get("kind", "")
    url = data.get("url", "")
    if not url:
        return

    subprocess.Popen(
        ["qtile", "cmd-obj", "-o", "group", "f", "-f", "toscreen"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    if kind == "tab":
        if not activate_vivaldi_tab(url):
            subprocess.Popen(
                ["/home/amos/scripts/vivaldi", url],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
    else:
        subprocess.Popen(
            ["/home/amos/scripts/vivaldi", url],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )


def delete_entry(data, current_query):
    url = data.get("url", "")
    kind = data.get("kind", "")
    if not url or kind != "hist":
        return
    subprocess.run(
        [HISTER_BIN, "delete", url],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    tab_result, seen = build_tab_entries(current_query)
    hist_result = build_hist_entries(current_query, seen)
    entries.clear()
    entries.extend(tab_result + hist_result)
    send({"lines": format_lines(entries)})


def main():
    global blocklist
    blocklist = load_blocklist()

    tab_result, _ = build_tab_entries("")
    entries.clear()
    entries.extend(tab_result)
    send({
        "input action": "send",
        "prompt": "Web❯",
        "event format": "{\"name\":\"{{name_escaped}}\", \"value\":\"{{value_escaped}}\", \"data\":\"{{data_escaped}}\"}",
        "lines": format_lines(entries),
    })

    current_query = ""
    debounce_timer = None
    DEBOUNCE_DELAY = 0.15

    def do_hist_search(query):
        try:
            seen = set(u for _, _, u in entries)
            hist = build_hist_entries(query, seen)
            if hist:
                entries.extend(hist)
                send({"lines": format_lines(entries)})
        except Exception:
            pass

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue

        name = event.get("name", "")
        value = event.get("value", "")
        raw_data = event.get("data", "")

        if name == "input change":
            current_query = value
            if debounce_timer is not None:
                debounce_timer.cancel()
            tab_result, _ = build_tab_entries(value)
            entries.clear()
            entries.extend(tab_result)
            send({"lines": format_lines(entries)})
            if value and value.strip():
                debounce_timer = threading.Timer(DEBOUNCE_DELAY, do_hist_search, [value])
                debounce_timer.daemon = True
                debounce_timer.start()

        elif name == "select entry":
            try:
                data = json.loads(raw_data)
            except (json.JSONDecodeError, TypeError):
                continue
            open_entry(data)
            sys.exit(0)

        elif name == "delete entry":
            try:
                data = json.loads(raw_data)
            except (json.JSONDecodeError, TypeError):
                continue
            delete_entry(data, current_query)

        elif name == "execute custom input":
            open_or_search(current_query or value)
            sys.exit(0)


if __name__ == "__main__":
    main()
