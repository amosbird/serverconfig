{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
  },
  "snapshot": false,
  "formatter": false,
  "lsp": false,
  "plugin": [],
  "mcp": {
    "iWiki": {
      "type": "remote",
      "url": "{env:IWIKI_MCP_URL}",
      "headers": {
        "Authorization": "{env:IWIKI_MCP_TOKEN}"
      },
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    }
  },
  "permission": {
    "*": "allow",
    "lsp": "deny",
    "bash": {
      "*": "allow",
      "rm -rf /*": "deny",
      "git push *--force*": "deny",
      "git reset --hard*": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "*": "allow"
    }
  }
}
