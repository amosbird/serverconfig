{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "iWiki": {
      "type": "remote",
      "url": "{env:IWIKI_MCP_URL}",
      "headers": {
        "Authorization": "{env:IWIKI_MCP_TOKEN}"
      },
      "enabled": true
    }
  },
  "permission": {
    "lsp": "deny",
    "external_directory": {
      "/tmp": "allow",
      "/tmp/**": "allow"
    }
  }
}
