{
  "$schema": "https://charm.land/crush.json",
  "mcp": {
    "iWiki": {
      "type": "http",
      "url": "$IWIKI_MCP_URL",
      "headers": {
        "Authorization": "$IWIKI_MCP_TOKEN"
      },
      "disabled": true
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$CONTEXT7_API_KEY"
      }
    },
    "grep_app": {
      "type": "http",
      "url": "https://mcp.grep.app",
      "disabled": true
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "headers": {
        "x-api-key": "$EXA_API_KEY"
      },
      "disabled": true
    }
  },
  "options": {
    "disable_metrics": true,
    "disable_provider_auto_update": true,
    "auto_lsp": false,
    "auto_title": false,
    "context_paths": [
      "~/.config/crush/AGENTS.md"
    ],
    "attribution": {
      "trailer_style": "none",
      "generated_with": false
    },
    "sandbox": true,
    "sandbox_symlink_depth": 1
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "ls",
      "grep"
    ],
    "auto_approve_working_dir": true
  },
  "providers": {
    "copilot": {
      "name": "GitHub Copilot",
      "type": "openai-compat",
      "base_url": "http://127.0.0.1:8787/v1",
      "api_key": "copilot-proxy",
      "models": [
        {
          "id": "claude-opus-4.6-1m",
          "name": "Claude Opus 4.6 (1M context)(Internal only)",
          "context_window": 1000000,
          "default_max_tokens": 64000
        },
        {
