{
  "$schema": "https://charm.land/crush.json",
  "mcp": {
    "iWiki": {
      "type": "http",
      "url": "$IWIKI_MCP_URL",
      "headers": {
        "Authorization": "$IWIKI_MCP_TOKEN"
      },
      "disabled": true
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$CONTEXT7_API_KEY"
      }
    },
    "grep_app": {
      "type": "http",
      "url": "https://mcp.grep.app",
      "disabled": true
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "headers": {
        "x-api-key": "$EXA_API_KEY"
      },
      "disabled": true
    }
  },
  "options": {
    "yolo": true,
    "disable_metrics": true,
    "disable_provider_auto_update": true,
    "max_tokens_to_summarize": 500000,
    "auto_lsp": false,
    "auto_title": false,
    "context_paths": [
      "~/.config/crush/AGENTS.md"
    ],
    "attribution": {
      "trailer_style": "none",
      "generated_with": false
    }
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "ls",
      "grep"
    ],
    "auto_approve_working_dir": true
  }
}
